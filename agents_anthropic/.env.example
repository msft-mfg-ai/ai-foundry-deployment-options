# Copy this file to .env and fill in your values
# Get these values after running: azd up in options-infra/ai-gateway-anthropic

# APIM gateway URL (output from azd: apim_gateway_url)
APIM_GATEWAY_URL=https://<apim-name>.azure-api.net

# APIM subscription key — get from Azure portal or:
#   az apim subscription list --resource-group <rg> --service-name <apim-name> --query "[0].primaryKey" -o tsv
APIM_SUBSCRIPTION_KEY=<your-apim-subscription-key>

# Model to use (must match a static model in your ai-gateway-anthropic deployment)
ANTHROPIC_MODEL=claude-opus-4-6

# Optional: Foundry project connection string for agent-based testing
# AZURE_AI_FOUNDRY_CONNECTION_STRING=<project-connection-string>
