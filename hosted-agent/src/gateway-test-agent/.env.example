# ── Foundry platform (auto-injected in hosted containers) ────────────────────
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# ── Model selection (set in azure.yaml environmentVariables) ────────────────
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# ── Copilot SDK runtime (set in azure.yaml) ─────────────────────────────────
COPILOT_CLI_EXTRACT_DIR=/opt/copilot-runtime
COPILOT_SKIP_CLI_DOWNLOAD=1

# ── Default test target (overridable per /responses call) ────────────────────
APIM_GATEWAY_URL=https://apim-ai-63fhh7glaqhvw.azure-api.net
TENANT_ID=c29d6c2b-f765-41b3-b2a2-971a14239dfd
TEST_MODEL=gpt-5-mini
