<policies>
    <!--
        Realtime (WebSocket) onHandshake routing policy
        ===============================================
        Applied to the auto-created `onHandshake` operation of the realtime
        WebSocket API. WebSocket APIs cannot use APIM backend *pools* (a
        connection is 1:1 between client and backend and can't be
        load-balanced), so instead of `set-backend-service backend-id="<pool>"`
        we route per-deployment to a concrete `wss://` base URL via
        `set-backend-service base-url="…"`.

        Token replacement (done in v2/realtime-ws-api.bicep before load):
          {JWT_VALIDATION}  optional <validate-jwt> block (empty = no inbound
                            caller-token validation).
          {ROUTING_MAP}     XML-encoded JSON object mapping deployment/model
                            name -> wss base URL, e.g.
                            {"gpt-realtime":"wss://acct.openai.azure.com/openai/realtime"}.

        Flow:
          1. (optional) validate the caller's Entra ID token.
          2. Read the requested deployment from the `deployment` query param
             (legacy realtime URL) falling back to `model` (GA realtime URL).
          3. Look the deployment up in the routing map and override the backend
             base URL. Unknown/empty deployments fall back to the first entry.
          4. Acquire an APIM managed-identity token for Cognitive Services and
             set it as the backend `Authorization` header (replaces the caller
             token). APIM's system-assigned identity has `Cognitive Services
             User` on every backing Foundry instance.

        Supported on onHandshake: base, validate-jwt, set-variable,
        set-backend-service, authentication-managed-identity, set-header
        (except well-known headers like Host). Unsupported (do NOT add here):
        set-body, set-request-method, validate-content/parameters/headers,
        cache, cors.
    -->
    <inbound>
        <base />
        {JWT_VALIDATION}
        <!-- Routing map: deployment/model name -> wss base URL. -->
        <set-variable name="realtimeRoutingMap" value="{ROUTING_MAP}" />
        <!-- Requested deployment: `deployment` (legacy) then `model` (GA). -->
        <set-variable name="requestedDeployment" value="@{
            var dep = context.Request.Url.Query.GetValueOrDefault(&quot;deployment&quot;, &quot;&quot;);
            if (string.IsNullOrEmpty(dep)) {
                dep = context.Request.Url.Query.GetValueOrDefault(&quot;model&quot;, &quot;&quot;);
            }
            return dep ?? &quot;&quot;;
        }" />
        <!-- Resolve the backend wss base URL from the map. -->
        <set-variable name="realtimeBackendUrl" value="@{
            var map = Newtonsoft.Json.JsonConvert.DeserializeObject&lt;System.Collections.Generic.Dictionary&lt;string, string&gt;&gt;((string)context.Variables[&quot;realtimeRoutingMap&quot;]);
            var dep = (string)context.Variables[&quot;requestedDeployment&quot;];
            if (!string.IsNullOrEmpty(dep) &amp;&amp; map.ContainsKey(dep)) {
                return map[dep];
            }
            foreach (var kv in map) {
                return kv.Value;
            }
            return &quot;&quot;;
        }" />
        <set-backend-service base-url="@((string)context.Variables[&quot;realtimeBackendUrl&quot;])" />
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="managed-id-access-token" ignore-error="false" />
        <set-header name="Authorization" exists-action="override">
            <value>@("Bearer " + (string)context.Variables["managed-id-access-token"])</value>
        </set-header>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
