<fragment>
    <!--
        Per-Model Routing Fragment
        ==========================
        Extracts the requested model name from the inbound request and picks
        the matching per-model APIM backend pool (created by
        advanced/multi-foundry-backends.bicep with the naming convention
        `{model-clean}-payg-pool`).

        Output context variables (for downstream policies / observability):
          - requestedModel  raw model name from the URL or request body
          - model-clean     model name with `.` and `-` stripped
          - backend-pool    name of the chosen pool

        Side-effect:
          - `set-backend-service backend-id="…"` selects the per-model pool.

        Reusable across multiple inference APIs (e.g. the Foundry-facing
        passthrough at `inference/openai/*` and a spec-backed AzureOpenAI API
        at `openai/*`). The fragment is auth-/transport-agnostic — it only
        reads from `context.Request`.
    -->

    <!-- Extract requested model from URL path or request body.
         Path shape (AzureOpenAI): /…/openai/deployments/{model}/... -->
    <set-variable name="requestedModel" value="@{
        var segments = context.Request.Url.Path.Split('/');
        for (int i = 0; i &lt; segments.Length - 1; i++) {
            if (segments[i] == &quot;deployments&quot; &amp;&amp; i + 1 &lt; segments.Length) {
                return segments[i + 1];
            }
        }
        try {
            var body = context.Request.Body.As&lt;Newtonsoft.Json.Linq.JObject&gt;(preserveContent: true);
            var model = body?[&quot;model&quot;];
            if (model != null &amp;&amp; !string.IsNullOrEmpty(model.ToString())) {
                return model.ToString();
            }
        } catch { }
        return &quot;unknown&quot;;
    }" />

    <!-- Compute pool name — must match advanced/multi-foundry-backends.bicep. -->
    <set-variable name="model-clean" value="@(((string)context.Variables[&quot;requestedModel&quot;]).Replace(&quot;.&quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;))" />
    <set-variable name="backend-pool" value="@((string)context.Variables[&quot;model-clean&quot;] + &quot;-payg-pool&quot;)" />

    <!-- Route to the per-model pool. `backend-id` accepts a pool name when the
         backend resource is of type `Pool`. -->
    <set-backend-service backend-id="@((string)context.Variables[&quot;backend-pool&quot;])" />
</fragment>
