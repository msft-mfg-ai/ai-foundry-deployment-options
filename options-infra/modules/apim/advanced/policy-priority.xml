<policies>
    <inbound>
        <base />

        <!-- ================================================================ -->
        <!-- STEP 1: Validate Bearer Token against Entra ID                   -->
        <!-- ================================================================ -->
        <validate-azure-ad-token
            tenant-id="{tenant-id}"
            header-name="Authorization"
            failed-validation-httpcode="401"
            failed-validation-error-message="Unauthorized. A valid Entra ID bearer token is required."
            output-token-variable-name="jwt">
            <audiences>
                <!-- Use Cognitive Services audience so Foundry-integrated clients work natively -->
                <audience>https://cognitiveservices.azure.com</audience>
            </audiences>
        </validate-azure-ad-token>

        <!-- ================================================================ -->
        <!-- STEP 2: Extract caller identity claims from JWT                    -->
        <!--                                                                    -->
        <!-- Different identity types surface in different claims:              -->
        <!--   azp/appid  — app registrations (service principal tokens)        -->
        <!--   xms_mirid  — managed identities (full Azure resource ID)         -->
        <!--   oid        — object ID (fallback for any Entra identity)         -->
        <!-- We extract all available claims; the identity lookup will match    -->
        <!-- against the correct one based on each identity's claimName.        -->
        <!-- ================================================================ -->
        <set-variable name="claim-azp" value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;azp&quot;, &quot;&quot;))" />
        <set-variable name="claim-appid" value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;appid&quot;, &quot;&quot;))" />
        <set-variable name="claim-xms_mirid" value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;xms_mirid&quot;, &quot;&quot;))" />
        <set-variable name="claim-oid" value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;oid&quot;, &quot;&quot;))" />
        <set-variable name="claim-sub" value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;sub&quot;, &quot;&quot;))" />

        <!-- Build a caller label for logging (best available identifier) -->
        <set-variable name="caller-id" value="@{
            var azp = (string)context.Variables[&quot;claim-azp&quot;];
            if (!string.IsNullOrEmpty(azp)) { return azp; }
            var appid = (string)context.Variables[&quot;claim-appid&quot;];
            if (!string.IsNullOrEmpty(appid)) { return appid; }
            var mirid = (string)context.Variables[&quot;claim-xms_mirid&quot;];
            if (!string.IsNullOrEmpty(mirid)) { return mirid; }
            var oid = (string)context.Variables[&quot;claim-oid&quot;];
            if (!string.IsNullOrEmpty(oid)) { return oid; }
            return &quot;unknown&quot;;
        }" />

        <!-- ================================================================ -->
        <!-- STEP 3: Load contract config from blob (cached 5 min)            -->
        <!--                                                                  -->
        <!-- First request: fetches from Blob Storage via managed identity    -->
        <!-- Subsequent: reads from APIM internal cache (300s TTL)            -->
        <!-- ================================================================ -->
        <cache-lookup-value key="contracts-blob-cache" variable-name="contracts-json" />
        <choose>
            <when condition="@(!context.Variables.ContainsKey(&quot;contracts-json&quot;))">
                <send-request mode="new" response-variable-name="contracts-response" timeout="10" ignore-error="false">
                    <set-url>{contracts-blob-url}</set-url>
                    <set-method>GET</set-method>
                    <set-header name="x-ms-version" exists-action="override">
                        <value>2020-04-08</value>
                    </set-header>
                    <authentication-managed-identity resource="https://storage.azure.com/" />
                </send-request>
                <set-variable name="contracts-json" value="@(((IResponse)context.Variables[&quot;contracts-response&quot;]).Body.As&lt;string&gt;())" />
                <cache-store-value key="contracts-blob-cache" value="@((string)context.Variables[&quot;contracts-json&quot;])" duration="300" />
            </when>
        </choose>

        <!-- Parse caller's contract using identity prefix matching -->
        <!-- The blob has { contracts: {...}, identities: [{value, claimName, contract}, ...] } -->
        <set-variable name="contracts-parsed" value="@(Newtonsoft.Json.Linq.JObject.Parse((string)context.Variables[&quot;contracts-json&quot;]))" />
        <set-variable name="contract-match" value="@{
            try {
                var root = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contracts-parsed&quot;];
                var identities = root[&quot;identities&quot;] as Newtonsoft.Json.Linq.JArray;
                if (identities == null) { return null; }

                // Build a dictionary of claim values for fast lookup
                var claims = new System.Collections.Generic.Dictionary&lt;string, string&gt;();
                claims[&quot;azp&quot;] = (string)context.Variables[&quot;claim-azp&quot;];
                claims[&quot;appid&quot;] = (string)context.Variables[&quot;claim-appid&quot;];
                claims[&quot;xms_mirid&quot;] = (string)context.Variables[&quot;claim-xms_mirid&quot;];
                claims[&quot;oid&quot;] = (string)context.Variables[&quot;claim-oid&quot;];
                claims[&quot;sub&quot;] = (string)context.Variables[&quot;claim-sub&quot;];

                // Iterate identities, find first prefix match
                foreach (var identity in identities)
                {
                    var claimNameToken = identity[&quot;claimName&quot;];
                    var prefixToken = identity[&quot;value&quot;];
                    var contractToken = identity[&quot;contract&quot;];

                    if (claimNameToken == null || prefixToken == null || contractToken == null) { continue; }

                    var claimName = claimNameToken.ToString();
                    var prefix = prefixToken.ToString();
                    var contractName = contractToken.ToString();

                    if (string.IsNullOrEmpty(claimName) || string.IsNullOrEmpty(prefix) || string.IsNullOrEmpty(contractName)) { continue; }

                    string claimValue;
                    if (!claims.TryGetValue(claimName, out claimValue) || string.IsNullOrEmpty(claimValue))
                    {
                        // azp (v2) and appid (v1) are equivalent — fall back across token versions
                        if (claimName == &quot;azp&quot;) { claims.TryGetValue(&quot;appid&quot;, out claimValue); }
                        else if (claimName == &quot;appid&quot;) { claims.TryGetValue(&quot;azp&quot;, out claimValue); }
                        if (string.IsNullOrEmpty(claimValue)) { continue; }
                    }

                    if (claimValue.StartsWith(prefix))
                    {
                        var displayToken = identity[&quot;displayName&quot;];
                        var matchedName = displayToken != null ? displayToken.ToString() : prefix;
                        var contracts = root[&quot;contracts&quot;] as Newtonsoft.Json.Linq.JObject;
                        var contractObj = contracts != null ? contracts[contractName] : null;
                        var result = new Newtonsoft.Json.Linq.JObject();
                        result[&quot;contract&quot;] = contractObj;
                        result[&quot;matchedIdentity&quot;] = matchedName;
                        return result;
                    }
                }
                return null;
            } catch {
                return null;
            }
        }" />

        <set-variable name="contract-obj" value="@{
            var match = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contract-match&quot;];
            if (match == null) { return null; }
            return match[&quot;contract&quot;];
        }" />
        <set-variable name="matched-identity" value="@{
            var match = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contract-match&quot;];
            if (match == null) { return &quot;unknown&quot;; }
            var v = match[&quot;matchedIdentity&quot;];
            return v != null ? v.ToString() : &quot;unknown&quot;;
        }" />

        <!-- ================================================================ -->
        <!-- STEP 4: Authorization — reject unknown callers                   -->
        <!-- ================================================================ -->
        <choose>
            <when condition="@(context.Variables[&quot;contract-obj&quot;] == null)">
                <return-response>
                    <set-status code="403" reason="Forbidden" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        var callerId = (string)context.Variables["caller-id"];
                        return "{\"error\": \"forbidden\", \"message\": \"Identity '" + callerId + "' does not match any access contract. Contact the platform team to request access.\"}";
                    }</set-body>
                </return-response>
            </when>
        </choose>

        <!-- Extract contract fields into typed variables -->
        <set-variable name="caller-name" value="@{
            var c = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contract-obj&quot;];
            var v = c[&quot;name&quot;]; return v != null ? v.ToString() : &quot;unknown&quot;;
        }" />
        <set-variable name="priority" value="@{
            var c = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contract-obj&quot;];
            var v = c[&quot;priority&quot;]; return v != null ? v.Value&lt;int&gt;() : 3;
        }" />
        <set-variable name="caller-monthly-quota" value="@{
            var c = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contract-obj&quot;];
            var v = c[&quot;monthlyQuota&quot;]; return v != null ? v.Value&lt;long&gt;() : (long)0;
        }" />
        <set-variable name="caller-environment" value="@{
            var c = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contract-obj&quot;];
            var v = c[&quot;environment&quot;]; return v != null ? v.ToString() : &quot;UNKNOWN&quot;;
        }" />
        <set-variable name="contract-models" value="@(((Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contract-obj&quot;])[&quot;models&quot;])" />

        <!-- Derive priority label for headers/logging -->
        <set-variable name="priority-label" value="@{
            var p = (int)context.Variables[&quot;priority&quot;];
            return p == 1 ? &quot;production&quot; : p == 2 ? &quot;standard&quot; : &quot;batch&quot;;
        }" />

        <!-- ================================================================ -->
        <!-- STEP 5: Extract requested model from URL path or request body   -->
        <!-- ================================================================ -->
        <set-variable name="requestedModel" value="@{
            // Try URL pattern first: /openai/deployments/{model}/chat/completions
            var segments = context.Request.Url.Path.Split('/');
            for (int i = 0; i < segments.Length - 1; i++) {
                if (segments[i] == &quot;deployments&quot; &amp;&amp; i + 1 < segments.Length) {
                    return segments[i + 1];
                }
            }
            // Fall back to request body 'model' field
            try {
                var body = context.Request.Body.As&lt;Newtonsoft.Json.Linq.JObject&gt;(preserveContent: true);
                var model = body?[&quot;model&quot;];
                if (model != null &amp;&amp; !string.IsNullOrEmpty(model.ToString())) {
                    return model.ToString();
                }
            } catch { }
            return &quot;unknown&quot;;
        }" />

        <!-- ================================================================ -->
        <!-- STEP 6: Validate model access + extract per-model limits         -->
        <!--                                                                  -->
        <!-- The models object is { "gpt-4o": { tpm: 4000, ptuTpm: 2000 } }  -->
        <!-- If the requested model isn't in the map → 403.                   -->
        <!-- ================================================================ -->
        <set-variable name="model-config" value="@{
            var models = (Newtonsoft.Json.Linq.JToken)context.Variables[&quot;contract-models&quot;];
            if (models == null) { return null; }
            var requested = (string)context.Variables[&quot;requestedModel&quot;];
            var cfg = models[requested];
            return cfg;
        }" />

        <choose>
            <when condition="@(context.Variables[&quot;model-config&quot;] == null)">
                <return-response>
                    <set-status code="403" reason="Forbidden" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        var model = (string)context.Variables["requestedModel"];
                        var models = (Newtonsoft.Json.Linq.JToken)context.Variables["contract-models"];
                        var allowed = models != null ? string.Join(", ", ((Newtonsoft.Json.Linq.JObject)models).Properties().Select(p => p.Name)) : "none";
                        return "{\"error\": \"model_not_authorized\", \"message\": \"Model '" + model + "' is not in your access contract. Allowed: " + allowed + "\"}";
                    }</set-body>
                </return-response>
            </when>
        </choose>

        <!-- Extract per-model TPM and PTU TPM from the model config -->
        <set-variable name="model-tpm" value="@{
            var m = (Newtonsoft.Json.Linq.JToken)context.Variables[&quot;model-config&quot;];
            var v = m[&quot;tpm&quot;]; return v != null ? v.Value&lt;int&gt;() : 10000;
        }" />
        <set-variable name="model-ptu-tpm" value="@{
            var m = (Newtonsoft.Json.Linq.JToken)context.Variables[&quot;model-config&quot;];
            var v = m[&quot;ptuTpm&quot;]; return v != null ? v.Value&lt;int&gt;() : 0;
        }" />

        <!-- Build allowed models list for response headers -->
        <set-variable name="allowed-models" value="@{
            var models = (Newtonsoft.Json.Linq.JToken)context.Variables[&quot;contract-models&quot;];
            if (models == null) { return &quot;&quot;; }
            return string.Join(&quot;,&quot;, ((Newtonsoft.Json.Linq.JObject)models).Properties().Select(p =&gt; p.Name));
        }" />

        <!-- ================================================================ -->
        <!-- STEP 7a: Enforce PER-MODEL TPM (hard limit)                      -->
        <!--                                                                  -->
        <!-- counter-key = contractName:model — all identities in a contract  -->
        <!-- share the same per-model TPM counter. This controls fair sharing -->
        <!-- of each model's capacity.                                        -->
        <!-- ================================================================ -->
        <llm-token-limit
            counter-key="@((string)context.Variables[&quot;caller-name&quot;] + &quot;:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
            tokens-per-minute="@((int)context.Variables[&quot;model-tpm&quot;])"
            estimate-prompt-tokens="true"
            remaining-tokens-header-name="x-ratelimit-remaining-tokens"
            tokens-consumed-header-name="x-tokens-consumed" />

        <!-- ================================================================ -->
        <!-- STEP 7b: Enforce MONTHLY QUOTA across all models (cost cap)      -->
        <!--                                                                  -->
        <!-- counter-key = contractName — all identities + all models in a    -->
        <!-- contract share one monthly quota counter.                        -->
        <!-- tokens-per-minute set very high (not the real limit — that's 7a) -->
        <!-- Only the monthly token-quota matters here.                       -->
        <!-- ================================================================ -->
        <llm-token-limit
            counter-key="@((string)context.Variables[&quot;caller-name&quot;])"
            tokens-per-minute="10000000"
            token-quota="@((long)context.Variables[&quot;caller-monthly-quota&quot;])"
            token-quota-period="Monthly"
            estimate-prompt-tokens="true"
            remaining-quota-tokens-header-name="x-quota-remaining-tokens" />

        <!-- ================================================================ -->
        <!-- STEP 8: Three-Priority Routing with PTU Quota                    -->
        <!--                                                                  -->
        <!-- Two caches feed the routing decision:                            -->
        <!--   A) ptu-remaining:{model} — global PTU capacity (for P2 check)  -->
        <!--   B) ptu-consumed:{azp}:{model} — per-team PTU usage (quota)     -->
        <!--                                                                  -->
        <!-- Single pool per model: {model-clean}-pool                        -->
        <!-- Pool has PTU backends (P1/P2) and paygo backends (P3).           -->
        <!-- All priorities use the same pool — APIM pool priority handles    -->
        <!-- the PTU → paygo failover via circuit breaker.                    -->
        <!--                                                                  -->
        <!-- Contract priority (P1/P2/P3) controls WHO gets to use the pool:  -->
        <!--   P1 (prod) → always routed to pool (PTU tried first by pool)    -->
        <!--   P2 (dev)  → routed to pool only if PTU utilization < threshold -->
        <!--   P3 (batch) → routed to pool (paygo backends only via policy)   -->
        <!-- ================================================================ -->

        <!-- Read cached global PTU consumption (total tokens routed to PTU, set by outbound) -->
        <cache-lookup-value
            key="@(&quot;ptu-consumed-global:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
            variable-name="ptu-consumed-global-cached"
            default-value="0" />

        <!-- Read this team's PTU consumption in current window -->
        <cache-lookup-value
            key="@(&quot;ptu-consumed:&quot; + (string)context.Variables[&quot;caller-name&quot;] + &quot;:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
            variable-name="ptu-consumed-cached"
            default-value="0" />

        <!-- PTU capacity is per-model, stored in the contracts blob -->
        <set-variable name="ptu-capacity" value="@{
            var root = (Newtonsoft.Json.Linq.JObject)context.Variables[&quot;contracts-parsed&quot;];
            var model = (string)context.Variables[&quot;requestedModel&quot;];
            var ptuCap = root[&quot;ptuCapacity&quot;] as Newtonsoft.Json.Linq.JObject;
            if (ptuCap == null) { return 100000; }
            var val = ptuCap[model];
            if (val == null) { return 100000; }
            return val.Value&lt;int&gt;();
        }" />

        <!-- Calculate PTU utilization from tracked consumption vs capacity -->
        <set-variable name="ptu-utilization" value="@{
            var consumedStr = (string)context.Variables[&quot;ptu-consumed-global-cached&quot;];
            double consumed;
            if (!double.TryParse(consumedStr, out consumed)) { return 0.0; }
            var capacity = (int)context.Variables[&quot;ptu-capacity&quot;];
            if (capacity &lt;= 0) { return 1.0; }
            var util = consumed / capacity;
            return util &lt; 0.0 ? 0.0 : util > 1.0 ? 1.0 : util;
        }" />

        <!-- Check if team has PTU quota remaining for THIS MODEL (soft limit) -->
        <set-variable name="ptu-quota-available" value="@{
            var ptuLimit = (int)context.Variables[&quot;model-ptu-tpm&quot;];
            if (ptuLimit &lt;= 0) { return false; } // No PTU allocation for this model
            var consumed = 0;
            int.TryParse((string)context.Variables[&quot;ptu-consumed-cached&quot;], out consumed);
            return consumed &lt; ptuLimit;
        }" />

        <!-- P2 routing threshold (default 0.7 = 70%) -->
        <set-variable name="ptu-threshold" value="@{
            var t = &quot;{ptu-utilization-threshold}&quot;;
            double val;
            return double.TryParse(t, out val) ? val : 0.7;
        }" />

        <!-- Build pool ID from model name (single pool per model) -->
        <set-variable name="model-clean" value="@(((string)context.Variables[&quot;requestedModel&quot;]).Replace(&quot;.&quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;))" />
        <set-variable name="pool-id" value="@((string)context.Variables[&quot;model-clean&quot;] + &quot;-pool&quot;)" />

        <!-- Priority routing decision -->
        <!-- All priorities use the same pool. The pool's internal priority  -->
        <!-- (PTU P1/P2, paygo P3) handles backend selection + failover.    -->
        <!-- Contract priority controls access, not pool selection.          -->
        <choose>
            <!-- P1 (prod): Always route to pool — PTU tried first by pool priority -->
            <when condition="@((int)context.Variables[&quot;priority&quot;] == 1)">
                <set-variable name="route-target" value="pool" />
                <set-backend-service backend-id="@((string)context.Variables[&quot;pool-id&quot;])" />
            </when>

            <!-- P2 (dev): Route to pool only if PTU utilization < threshold AND quota available -->
            <!-- If PTU is busy, P2 still uses the pool (paygo backends are in there too) -->
            <when condition="@((int)context.Variables[&quot;priority&quot;] == 2)">
                <set-variable name="route-target" value="pool" />
                <set-backend-service backend-id="@((string)context.Variables[&quot;pool-id&quot;])" />
            </when>

            <!-- P3 (batch): Route to pool — will naturally land on paygo (P3 backends) -->
            <!-- since PTU backends are higher priority in pool, P3 traffic only reaches -->
            <!-- paygo when PTU is healthy (but that's fine — P3 is cost-insensitive)   -->
            <otherwise>
                <set-variable name="route-target" value="pool" />
                <set-backend-service backend-id="@((string)context.Variables[&quot;pool-id&quot;])" />
            </otherwise>
        </choose>

        <!-- ================================================================ -->
        <!-- STEP 9: Set tracing headers + backend auth                       -->
        <!-- ================================================================ -->
        <set-header name="x-caller-id" exists-action="override">
            <value>@((string)context.Variables["caller-id"])</value>
        </set-header>
        <set-header name="x-caller-identity" exists-action="override">
            <value>@((string)context.Variables.GetValueOrDefault("matched-identity", "unknown"))</value>
        </set-header>
        <set-header name="x-caller-name" exists-action="override">
            <value>@((string)context.Variables["caller-name"])</value>
        </set-header>
        <set-header name="x-caller-priority" exists-action="override">
            <value>@((string)context.Variables["priority-label"])</value>
        </set-header>
        <set-header name="x-route-target" exists-action="override">
            <value>@((string)context.Variables["route-target"])</value>
        </set-header>

        <!-- CORS for Azure AI Foundry portal -->
        <cors allow-credentials="true">
            <allowed-origins>
                <origin>https://ai.azure.com</origin>
            </allowed-origins>
            <allowed-methods preflight-result-max-age="300">
                <method>*</method>
            </allowed-methods>
            <allowed-headers>
                <header>*</header>
            </allowed-headers>
            <expose-headers>
                <header>*</header>
            </expose-headers>
        </cors>

        <!-- Authenticate to backend with APIM's managed identity -->
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="managed-id-access-token" ignore-error="false" />
        <set-header name="Authorization" exists-action="override">
            <value>@("Bearer " + (string)context.Variables["managed-id-access-token"])</value>
        </set-header>

        <!-- Emit token metrics with caller + routing dimensions -->
        <azure-openai-emit-token-metric namespace="openai">
            <dimension name="Caller ID" value="@((string)context.Variables[&quot;caller-id&quot;])" />
            <dimension name="Caller Name" value="@((string)context.Variables[&quot;caller-name&quot;])" />
            <dimension name="Priority" value="@((string)context.Variables[&quot;priority-label&quot;])" />
            <dimension name="Route Target" value="@((string)context.Variables[&quot;route-target&quot;])" />
            <dimension name="Model" value="@((string)context.Variables[&quot;requestedModel&quot;])" />
            <dimension name="API ID" value="@(context.Api.Id)" />
        </azure-openai-emit-token-metric>
    </inbound>

    <backend>
        <forward-request buffer-request-body="true" />
    </backend>

    <outbound>
        <base />

        <!-- ================================================================ -->
        <!-- Detect backend type: PTU or PAYG                                -->
        <!-- After forward-request through a pool, context.Request.Url.Host  -->
        <!-- reflects the actual backend that served the request.            -->
        <!-- {ptu-backend-hosts} is replaced at deploy time with a comma-    -->
        <!-- separated list of PTU endpoint hostnames.                       -->
        <!-- ================================================================ -->
        <set-variable name="backend-type" value="@{
            var ptuHosts = &quot;{ptu-backend-hosts}&quot;;
            if (string.IsNullOrEmpty(ptuHosts)) { return &quot;payg&quot;; }
            var host = context.Request.Url.Host.ToLower();
            foreach (var h in ptuHosts.Split(',')) {
                if (host == h.Trim().ToLower()) { return &quot;ptu&quot;; }
            }
            return &quot;payg&quot;;
        }" />

        <!-- ================================================================ -->
        <!-- Track PTU consumption from response body usage.total_tokens     -->
        <!-- Only tracked when the backend was actually PTU (not PAYG).      -->
        <!-- PTU deployments don't return rate-limit headers, so we read     -->
        <!-- actual token counts from the response body instead.             -->
        <!-- ================================================================ -->
        <set-variable name="actual-tokens" value="@{
            try {
                var body = context.Response.Body.As&lt;Newtonsoft.Json.Linq.JObject&gt;(preserveContent: true);
                var usage = body[&quot;usage&quot;] as Newtonsoft.Json.Linq.JObject;
                if (usage == null) { return 0; }
                var total = usage[&quot;total_tokens&quot;];
                return total != null ? total.Value&lt;int&gt;() : 0;
            } catch { return 0; }
        }" />

        <choose>
            <!-- Only track PTU consumption when backend was actually PTU AND priority <= 2 -->
            <when condition="@((string)context.Variables[&quot;backend-type&quot;] == &quot;ptu&quot; &amp;&amp; (int)context.Variables[&quot;priority&quot;] <= 2 &amp;&amp; (int)context.Variables[&quot;actual-tokens&quot;] > 0)">
                <!-- Accumulate global PTU consumption (for P2 utilization decisions) -->
                <cache-lookup-value
                    key="@(&quot;ptu-consumed-global:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
                    variable-name="prev-ptu-global"
                    default-value="0" />
                <cache-store-value
                    key="@(&quot;ptu-consumed-global:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
                    value="@{
                        var prev = 0;
                        int.TryParse((string)context.Variables[&quot;prev-ptu-global&quot;], out prev);
                        return (prev + (int)context.Variables[&quot;actual-tokens&quot;]).ToString();
                    }"
                    duration="60" />

                <!-- Accumulate per-team PTU consumption (for per-team PTU quota) -->
                <cache-lookup-value
                    key="@(&quot;ptu-consumed:&quot; + (string)context.Variables[&quot;caller-name&quot;] + &quot;:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
                    variable-name="prev-ptu-consumed"
                    default-value="0" />
                <cache-store-value
                    key="@(&quot;ptu-consumed:&quot; + (string)context.Variables[&quot;caller-name&quot;] + &quot;:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
                    value="@{
                        var prev = 0;
                        int.TryParse((string)context.Variables[&quot;prev-ptu-consumed&quot;], out prev);
                        return (prev + (int)context.Variables[&quot;actual-tokens&quot;]).ToString();
                    }"
                    duration="60" />
            </when>
        </choose>

        <!-- ================================================================ -->
        <!-- Response headers for observability                               -->
        <!-- ================================================================ -->
        <set-header name="x-ratelimit-limit-tokens" exists-action="override">
            <value>@(((int)context.Variables["model-tpm"]).ToString())</value>
        </set-header>
        <set-header name="x-quota-limit-tokens" exists-action="override">
            <value>@(((long)context.Variables["caller-monthly-quota"]).ToString())</value>
        </set-header>
        <set-header name="x-caller-name" exists-action="override">
            <value>@((string)context.Variables["caller-name"])</value>
        </set-header>
        <set-header name="x-caller-identity" exists-action="override">
            <value>@((string)context.Variables.GetValueOrDefault("matched-identity", "unknown"))</value>
        </set-header>
        <set-header name="x-caller-priority" exists-action="override">
            <value>@((string)context.Variables["priority-label"])</value>
        </set-header>
        <set-header name="x-route-target" exists-action="override">
            <value>@((string)context.Variables["route-target"])</value>
        </set-header>
        <set-header name="x-ptu-utilization" exists-action="override">
            <value>@(((double)context.Variables["ptu-utilization"] * 100).ToString("F1") + "%")</value>
        </set-header>
        <set-header name="x-ptu-consumed" exists-action="override">
            <value>@((string)context.Variables.GetValueOrDefault("ptu-consumed-cached", "0"))</value>
        </set-header>
        <set-header name="x-ptu-limit" exists-action="override">
            <value>@(((int)context.Variables["model-ptu-tpm"]).ToString())</value>
        </set-header>
        <set-header name="x-actual-tokens" exists-action="override">
            <value>@(((int)context.Variables["actual-tokens"]).ToString())</value>
        </set-header>
        <set-header name="x-backend-type" exists-action="override">
            <value>@((string)context.Variables["backend-type"])</value>
        </set-header>
    </outbound>

    <on-error>
        <base />
        <!-- ================================================================ -->
        <!-- EVENT HUB: Emit quota-exceeded event when monthly quota is hit   -->
        <!-- The logger-id placeholder is replaced at deploy time.            -->
        <!-- If empty (no Event Hub configured), this block is skipped.       -->
        <!-- ================================================================ -->
        <choose>
            <when condition="@(&quot;{eventhub-logger-id}&quot; != &quot;&quot; &amp;&amp; (context.LastError?.Message ?? &quot;&quot;).Contains(&quot;quota&quot;))">
                <log-to-eventhub logger-id="{eventhub-logger-id}">@{
                    var team   = (string)context.Variables.GetValueOrDefault("caller-name", "unknown");
                    var model  = (string)context.Variables.GetValueOrDefault("requestedModel", "unknown");
                    var msg    = context.LastError?.Message ?? "quota exceeded";
                    return new Newtonsoft.Json.Linq.JObject(
                        new Newtonsoft.Json.Linq.JProperty("event",     "quota_exceeded"),
                        new Newtonsoft.Json.Linq.JProperty("team",      team),
                        new Newtonsoft.Json.Linq.JProperty("model",     model),
                        new Newtonsoft.Json.Linq.JProperty("message",   msg),
                        new Newtonsoft.Json.Linq.JProperty("timestamp", DateTime.UtcNow.ToString("o")),
                        new Newtonsoft.Json.Linq.JProperty("requestId", context.RequestId.ToString())
                    ).ToString();
                }</log-to-eventhub>
            </when>
        </choose>
        <return-response>
            <set-status code="@(context.Response.StatusCode)" reason="@(context.Response.StatusReason)" />
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-header name="x-error-reason" exists-action="override">
                <value>@(context.LastError?.Reason ?? "unknown")</value>
            </set-header>
            <set-header name="x-error-message" exists-action="override">
                <value>@(context.LastError?.Message ?? "unknown")</value>
            </set-header>
            <set-header name="x-error-section" exists-action="override">
                <value>@(context.LastError?.Section ?? "unknown")</value>
            </set-header>
            <set-header name="x-error-source" exists-action="override">
                <value>@(context.LastError?.Source ?? "unknown")</value>
            </set-header>
            <set-header name="x-caller-id" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("caller-id", "unknown"))</value>
            </set-header>
            <set-header name="x-route-target" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("route-target", "unknown"))</value>
            </set-header>
            <set-body>@{
                var reason = context.LastError?.Reason ?? "unknown";
                var message = context.LastError?.Message ?? "An error occurred processing the request.";
                return new Newtonsoft.Json.Linq.JObject(
                    new Newtonsoft.Json.Linq.JProperty("error", new Newtonsoft.Json.Linq.JObject(
                        new Newtonsoft.Json.Linq.JProperty("code", reason),
                        new Newtonsoft.Json.Linq.JProperty("message", message)
                    ))
                ).ToString();
            }</set-body>
        </return-response>
    </on-error>
</policies>
