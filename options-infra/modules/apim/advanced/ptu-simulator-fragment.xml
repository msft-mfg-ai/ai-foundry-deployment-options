<!--
  ============================================================================
  PTU Simulator — Smart Mock (Outbound Policy Fragment)
  ============================================================================
  Purpose: Makes standard backends behave like PTU deployments for testing.
  Injects PTU-like response headers, tracks cumulative consumption, and
  simulates 429 rate-limit responses when "PTU capacity" is exhausted.

  How it works:
    1. Checks if simulation is enabled and response lacks real PTU headers
    2. Tracks cumulative token consumption per model in APIM cache (60s window)
    3. Calculates simulated remaining = capacity - baseUsed - consumed
    4. If remaining <= 0: rewrites response to 429 (simulating PTU exhaustion)
       This triggers the retry/circuit-breaker logic just like a real PTU would
    5. Otherwise: injects x-ratelimit-remaining-tokens header
       Downstream cache-tracking code can't tell the difference from real PTU

  Named Values required:
    ptu-simulator-enabled          = "true" / "false"
    ptu-simulator-capacity         = "100000" (simulated PTU capacity in TPM)
    ptu-simulator-base-utilization = "0.3" (baseline utilization 0.0-1.0)

  Install: Include this fragment in the outbound section BEFORE the real
  PTU cache-tracking logic. Mark a deployment as isPtu: true in the
  foundryInstances config to put it in the PTU pool for end-to-end testing.
  ============================================================================
-->

<!-- PTU Simulator: make standard backends behave like PTU -->
<choose>
    <when condition="@{
        var enabled = &quot;{{ptu-simulator-enabled}}&quot;;
        if (enabled != &quot;true&quot;) { return false; }

        // Only simulate if response doesn't already have real PTU headers
        return !context.Response.Headers.ContainsKey(&quot;x-ratelimit-remaining-tokens&quot;)
               || string.IsNullOrEmpty(context.Response.Headers.GetValueOrDefault(&quot;x-ratelimit-remaining-tokens&quot;, &quot;&quot;));
    }">
        <!-- Calculate simulated remaining tokens -->
        <set-variable name="sim-capacity" value="@{
            var cap = &quot;{{ptu-simulator-capacity}}&quot;;
            int val;
            return int.TryParse(cap, out val) ? val : 100000;
        }" />

        <set-variable name="sim-base-utilization" value="@{
            var util = &quot;{{ptu-simulator-base-utilization}}&quot;;
            double val;
            return double.TryParse(util, out val) ? val : 0.3;
        }" />

        <!-- Read how many tokens were consumed in this response -->
        <set-variable name="sim-consumed" value="@{
            var consumed = context.Response.Headers.GetValueOrDefault(&quot;x-tokens-consumed&quot;, &quot;0&quot;);
            int val;
            return int.TryParse(consumed, out val) ? val : 0;
        }" />

        <!-- Read cumulative simulated consumption from cache (60s rolling window) -->
        <cache-lookup-value
            key="@(&quot;ptu-sim-consumed:&quot; + (string)context.Variables.GetValueOrDefault(&quot;requestedModel&quot;, &quot;default&quot;))"
            variable-name="sim-cumulative"
            default-value="0" />

        <!-- Calculate simulated remaining -->
        <set-variable name="sim-remaining" value="@{
            var capacity = (int)context.Variables[&quot;sim-capacity&quot;];
            var baseUtil = (double)context.Variables[&quot;sim-base-utilization&quot;];
            var cumulative = int.Parse((string)context.Variables[&quot;sim-cumulative&quot;]);
            var consumed = (int)context.Variables[&quot;sim-consumed&quot;];
            var newCumulative = cumulative + consumed;

            // Remaining = capacity - (baseUtilization * capacity) - cumulativeConsumed
            var baseUsed = (int)(baseUtil * capacity);
            var remaining = capacity - baseUsed - newCumulative;
            return remaining;
        }" />

        <!-- Update cumulative consumed in cache (60s TTL = 1 minute window) -->
        <cache-store-value
            key="@(&quot;ptu-sim-consumed:&quot; + (string)context.Variables.GetValueOrDefault(&quot;requestedModel&quot;, &quot;default&quot;))"
            value="@{
                var cumulative = int.Parse((string)context.Variables[&quot;sim-cumulative&quot;]);
                var consumed = (int)context.Variables[&quot;sim-consumed&quot;];
                return (cumulative + consumed).ToString();
            }"
            duration="60" />

        <choose>
            <!-- Simulate PTU 429 when capacity exhausted -->
            <when condition="@((int)context.Variables[&quot;sim-remaining&quot;] &lt;= 0)">
                <set-header name="x-ptu-simulated" exists-action="override">
                    <value>true</value>
                </set-header>
                <set-header name="x-ptu-sim-remaining" exists-action="override">
                    <value>@(((int)context.Variables["sim-remaining"]).ToString())</value>
                </set-header>
                <return-response>
                    <set-status code="429" reason="Too Many Requests" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-header name="x-ratelimit-remaining-tokens" exists-action="override">
                        <value>0</value>
                    </set-header>
                    <set-header name="x-ratelimit-remaining-requests" exists-action="override">
                        <value>0</value>
                    </set-header>
                    <set-header name="Retry-After" exists-action="override">
                        <value>10</value>
                    </set-header>
                    <set-header name="x-ptu-simulated" exists-action="override">
                        <value>true</value>
                    </set-header>
                    <set-body>@{
                        return "{\"error\": {\"code\": \"429\", \"message\": \"[PTU Simulator] Rate limit reached. Simulated PTU capacity exhausted. Remaining: " + ((int)context.Variables["sim-remaining"]).ToString() + " tokens.\"}}";
                    }</set-body>
                </return-response>
            </when>

            <!-- PTU has capacity — inject simulated headers -->
            <otherwise>
                <set-header name="x-ratelimit-remaining-tokens" exists-action="override">
                    <value>@(Math.Max(0, (int)context.Variables["sim-remaining"]).ToString())</value>
                </set-header>
                <set-header name="x-ratelimit-remaining-requests" exists-action="override">
                    <value>100</value>
                </set-header>
                <set-header name="x-ptu-simulated" exists-action="override">
                    <value>true</value>
                </set-header>
                <set-header name="x-ptu-sim-remaining" exists-action="override">
                    <value>@(((int)context.Variables["sim-remaining"]).ToString())</value>
                </set-header>
            </otherwise>
        </choose>
    </when>
</choose>
