<policies>
    <inbound>
        <base />

        <!-- Step 1: Validate Bearer Token against Entra ID -->
        <validate-azure-ad-token
            tenant-id="{tenant-id}"
            header-name="Authorization"
            failed-validation-httpcode="401"
            failed-validation-error-message="Unauthorized. A valid Entra ID bearer token is required."
            output-token-variable-name="jwt">
            <audiences>
                <audience>{audience}</audience>
            </audiences>
        </validate-azure-ad-token>

        <!-- Step 2: Extract azp (authorized party) claim -->
        <set-variable name="azp" value="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;azp&quot;, ((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;appid&quot;, &quot;unknown&quot;)))" />

        <!-- Step 3: Load caller config from Named Value and parse all fields -->
        <set-variable name="caller-mapping" value="{{caller-tier-mapping}}" />
        <set-variable name="caller-config" value="@{
            try {
                var mapping = Newtonsoft.Json.Linq.JObject.Parse((string)context.Variables[&quot;caller-mapping&quot;]);
                var azp = (string)context.Variables[&quot;azp&quot;];
                var entry = mapping[azp];
                if (entry == null) { return &quot;&quot;; }
                return entry.ToString(Newtonsoft.Json.Formatting.None);
            } catch {
                return &quot;&quot;;
            }
        }" />
        <set-variable name="caller-tier" value="@{
            var cfg = (string)context.Variables[&quot;caller-config&quot;];
            if (string.IsNullOrEmpty(cfg)) { return &quot;&quot;; }
            try { return Newtonsoft.Json.Linq.JObject.Parse(cfg)[&quot;tier&quot;]?.ToString() ?? &quot;&quot;; }
            catch { return &quot;&quot;; }
        }" />
        <set-variable name="caller-name" value="@{
            var cfg = (string)context.Variables[&quot;caller-config&quot;];
            if (string.IsNullOrEmpty(cfg)) { return &quot;unknown&quot;; }
            try { return Newtonsoft.Json.Linq.JObject.Parse(cfg)[&quot;name&quot;]?.ToString() ?? &quot;unknown&quot;; }
            catch { return &quot;unknown&quot;; }
        }" />
        <set-variable name="caller-tpm" value="@{
            var cfg = (string)context.Variables[&quot;caller-config&quot;];
            if (string.IsNullOrEmpty(cfg)) { return &quot;10000&quot;; }
            try { return Newtonsoft.Json.Linq.JObject.Parse(cfg)[&quot;tpm&quot;]?.ToString() ?? &quot;10000&quot;; }
            catch { return &quot;10000&quot;; }
        }" />
        <set-variable name="caller-monthly-quota" value="@{
            var cfg = (string)context.Variables[&quot;caller-config&quot;];
            if (string.IsNullOrEmpty(cfg)) { return &quot;0&quot;; }
            try { return Newtonsoft.Json.Linq.JObject.Parse(cfg)[&quot;monthlyQuota&quot;]?.ToString() ?? &quot;0&quot;; }
            catch { return &quot;0&quot;; }
        }" />

        <!-- Step 4: Authorization check - reject unknown callers -->
        <choose>
            <when condition="@(string.IsNullOrEmpty((string)context.Variables[&quot;caller-tier&quot;]))">
                <return-response>
                    <set-status code="403" reason="Forbidden" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        var azp = (string)context.Variables["azp"];
                        return "{\"error\": \"forbidden\", \"message\": \"Application '" + azp + "' is not authorized. Contact the platform team to request access.\"}";
                    }</set-body>
                </return-response>
            </when>
        </choose>

        <!-- Step 5: Apply llm-token-limit with TPM + monthly quota from caller config -->
        <!-- TPM rate limit (429) + monthly token quota (403) enforced by APIM natively -->
        <llm-token-limit
            counter-key="@((string)context.Variables[&quot;azp&quot;])"
            tokens-per-minute="@(int.Parse((string)context.Variables[&quot;caller-tpm&quot;]))"
            token-quota="@(long.Parse((string)context.Variables[&quot;caller-monthly-quota&quot;]))"
            token-quota-period="Monthly"
            estimate-prompt-tokens="true"
            remaining-tokens-header-name="x-ratelimit-remaining-tokens"
            remaining-quota-tokens-header-name="x-quota-remaining-tokens"
            tokens-consumed-header-name="x-tokens-consumed" />

        <!-- Set headers for logging and tracing -->
        <set-header name="x-caller-azp" exists-action="override">
            <value>@((string)context.Variables["azp"])</value>
        </set-header>
        <set-header name="x-caller-name" exists-action="override">
            <value>@((string)context.Variables["caller-name"])</value>
        </set-header>
        <set-header name="x-caller-tier" exists-action="override">
            <value>@((string)context.Variables["caller-tier"])</value>
        </set-header>

        <!-- CORS for Azure AI Foundry portal -->
        <cors allow-credentials="true">
            <allowed-origins>
                <origin>https://ai.azure.com</origin>
            </allowed-origins>
            <allowed-methods preflight-result-max-age="300">
                <method>*</method>
            </allowed-methods>
            <allowed-headers>
                <header>*</header>
            </allowed-headers>
            <expose-headers>
                <header>*</header>
            </expose-headers>
        </cors>

        <!-- Authenticate to Azure OpenAI with APIM's managed identity -->
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="managed-id-access-token" ignore-error="false" />
        <set-header name="Authorization" exists-action="override">
            <value>@("Bearer " + (string)context.Variables["managed-id-access-token"])</value>
        </set-header>
        <set-backend-service backend-id="{backend-id}" />

        <!-- Emit token metrics with caller dimensions -->
        <azure-openai-emit-token-metric namespace="openai">
            <dimension name="Caller AZP" value="@((string)context.Variables[&quot;azp&quot;])" />
            <dimension name="Caller Name" value="@((string)context.Variables[&quot;caller-name&quot;])" />
            <dimension name="Caller Tier" value="@((string)context.Variables[&quot;caller-tier&quot;])" />
            <dimension name="API ID" value="@(context.Api.Id)" />
        </azure-openai-emit-token-metric>
    </inbound>
    <backend>
        <forward-request buffer-request-body="true" />
    </backend>
    <outbound>
        <base />
        <!-- x-ratelimit-remaining-tokens, x-quota-remaining-tokens, x-tokens-consumed set by llm-token-limit -->
        <set-header name="x-ratelimit-limit-tokens" exists-action="override">
            <value>@((string)context.Variables["caller-tpm"])</value>
        </set-header>
        <set-header name="x-quota-limit-tokens" exists-action="override">
            <value>@((string)context.Variables["caller-monthly-quota"])</value>
        </set-header>
        <set-header name="x-caller-tier" exists-action="override">
            <value>@((string)context.Variables["caller-tier"])</value>
        </set-header>
        <set-header name="x-caller-name" exists-action="override">
            <value>@((string)context.Variables["caller-name"])</value>
        </set-header>
    </outbound>
    <on-error>
        <base />
        <set-header name="x-error-reason" exists-action="override">
            <value>@(context.LastError?.Reason ?? "unknown")</value>
        </set-header>
        <set-header name="x-error-message" exists-action="override">
            <value>@(context.LastError?.Message ?? "unknown")</value>
        </set-header>
        <set-header name="x-error-section" exists-action="override">
            <value>@(context.LastError?.Section ?? "unknown")</value>
        </set-header>
        <set-header name="x-error-source" exists-action="override">
            <value>@(context.LastError?.Source ?? "unknown")</value>
        </set-header>
    </on-error>
</policies>
