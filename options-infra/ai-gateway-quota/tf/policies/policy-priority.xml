<policies>
    <inbound>
        <base />

        <!-- ================================================================ -->
        <!-- Identity & Authorization (shared policy fragment)                -->
        <!--                                                                  -->
        <!-- Sets: caller-id, caller-name, matched-identity, priority,        -->
        <!--        priority-label, caller-monthly-quota, contract-models,     -->
        <!--        requestedModel, model-config, model-tpm, model-ptu-tpm    -->
        <!-- ================================================================ -->
        <include-fragment fragment-id="identity-and-authorization" />

        <!-- ================================================================ -->
        <!-- STEP 7a: Enforce PER-MODEL TPM (hard limit, total across PTU+PAYG) -->
        <!--                                                                  -->
        <!-- This is the TOTAL tokens-per-minute budget for this model,       -->
        <!-- combining both PTU and PAYG usage. For Production callers with   -->
        <!-- PTU, the first ptu_tpm tokens route through PTU; the remainder  -->
        <!-- spills to PAYG — but both count against this single TPM cap.    -->
        <!--                                                                  -->
        <!-- counter-key = contractName:model — all identities in a contract  -->
        <!-- share the same per-model TPM counter.                            -->
        <!-- llm-token-limit handles token estimation internally.             -->
        <!-- https://learn.microsoft.com/en-us/azure/api-management/llm-token-limit-policy -->
        <!-- ================================================================ -->
        <llm-token-limit
            counter-key="@((string)context.Variables[&quot;caller-name&quot;] + &quot;:&quot; + (string)context.Variables[&quot;requestedModel&quot;])"
            tokens-per-minute="@((int)context.Variables[&quot;model-tpm&quot;])"
            estimate-prompt-tokens="false"
            remaining-tokens-header-name="x-ratelimit-remaining-tokens"
            tokens-consumed-header-name="x-tokens-consumed" />

        <!-- ================================================================ -->
        <!-- STEP 7b: Enforce MONTHLY QUOTA (cost cap)                        -->
        <!--                                                                  -->
        <!-- Applies to:                                                      -->
        <!--   • Standard callers (priority != 1) — always PAYG, always cost  -->
        <!--   • Production callers with partial PTU (ptu_tpm < tpm) — PAYG   -->
        <!--     spill-over is possible, so quota must be enforced.           -->
        <!--                                                                  -->
        <!-- Skipped for:                                                     -->
        <!--   • Production callers with 100% PTU (ptu_tpm == tpm) — all      -->
        <!--     traffic is pre-paid PTU, no PAYG cost possible.              -->
        <!--                                                                  -->
        <!-- Trade-off: for partial-PTU Production callers, PTU tokens also   -->
        <!-- count against the monthly quota. This slightly over-counts but   -->
        <!-- avoids the complexity of a separate PAYG gate loopback. The      -->
        <!-- alternative (exact PAYG-only counting) would require an extra    -->
        <!-- loopback API with its own llm-token-limit, since the policy      -->
        <!-- can only count tokens in inbound (before knowing which backend   -->
        <!-- will serve the request).                                         -->
        <!--                                                                  -->
        <!-- counter-key = contractName — shared across identities + models.  -->
        <!-- ================================================================ -->
        <choose>
            <when condition="@((int)context.Variables[&quot;priority&quot;] != 1 || (int)context.Variables[&quot;model-ptu-tpm&quot;] != (int)context.Variables[&quot;model-tpm&quot;])">
                <llm-token-limit
                    counter-key="@((string)context.Variables[&quot;caller-name&quot;])"
                    token-quota="@((long)context.Variables[&quot;caller-monthly-quota&quot;])"
                    token-quota-period="Monthly"
                    estimate-prompt-tokens="false"
                    remaining-quota-tokens-header-name="x-quota-remaining-tokens" 
                    tokens-consumed-header-name="x-quota-tokens-consumed" />
            </when>
        </choose>

        <!-- ================================================================ -->
        <!-- STEP 8: Routing                                                  -->
        <!--                                                                  -->
        <!-- Case A — Production (priority == 1, has PTU allocation):         -->
        <!--   → mixed pool (PTU at priority 1, PAYG at priority 2).          -->
        <!--     Circuit breaker on PTU backends handles failover to PAYG     -->
        <!--     automatically when PTU returns 429/503.                      -->
        <!--                                                                  -->
        <!-- Case B — Standard (or Production without PTU):                   -->
        <!--   → PAYG-only pool. Standard callers should not consume PTU.     -->
        <!-- ================================================================ -->

        <!-- Build pool IDs from model name -->
        <set-variable name="model-clean" value="@(((string)context.Variables[&quot;requestedModel&quot;]).Replace(&quot;.&quot;, &quot;&quot;).Replace(&quot;-&quot;, &quot;&quot;))" />
        <set-variable name="ptu-pool-id" value="@((string)context.Variables[&quot;model-clean&quot;] + &quot;-ptu-pool&quot;)" />
        <set-variable name="payg-pool-id" value="@((string)context.Variables[&quot;model-clean&quot;] + &quot;-payg-pool&quot;)" />

        <!-- Routing decision -->
        <choose>
            <!-- Case A: Production with PTU allocation → mixed pool (circuit breaker failover) -->
            <when condition="@((int)context.Variables[&quot;priority&quot;] == 1 &amp;&amp; (int)context.Variables[&quot;model-ptu-tpm&quot;] > 0)">
                <set-variable name="route-target" value="ptu" />
                <set-variable name="backend-pool" value="@((string)context.Variables[&quot;ptu-pool-id&quot;])" />
                <set-backend-service backend-id="@((string)context.Variables[&quot;ptu-pool-id&quot;])" />
            </when>

            <!-- Case B: Everything else → PAYG pool directly -->
            <otherwise>
                <set-variable name="route-target" value="payg" />
                <set-variable name="backend-pool" value="@((string)context.Variables[&quot;payg-pool-id&quot;])" />
                <set-backend-service backend-id="@((string)context.Variables[&quot;payg-pool-id&quot;])" />
            </otherwise>
        </choose>

        <!-- ================================================================ -->
        <!-- STEP 9: Tracing headers + backend auth                           -->
        <!-- ================================================================ -->
        <set-header name="x-caller-id" exists-action="override">
            <value>@((string)context.Variables["caller-id"])</value>
        </set-header>
        <set-header name="x-caller-identity" exists-action="override">
            <value>@((string)context.Variables.GetValueOrDefault("matched-identity", "unknown"))</value>
        </set-header>
        <set-header name="x-caller-name" exists-action="override">
            <value>@((string)context.Variables["caller-name"])</value>
        </set-header>
        <set-header name="x-caller-priority" exists-action="override">
            <value>@((string)context.Variables["priority-label"])</value>
        </set-header>
        <set-header name="x-route-target" exists-action="override">
            <value>@((string)context.Variables["route-target"])</value>
        </set-header>

        <!-- Extract Foundry-specific headers for observability -->
        <set-variable name="foundry-agent-id" value="@(context.Request.Headers.GetValueOrDefault(&quot;x-ms-foundry-agent-id&quot;, &quot;&quot;))" />
        <set-variable name="foundry-project-name" value="@(context.Request.Headers.GetValueOrDefault(&quot;openai-project&quot;, &quot;&quot;))" />
        <set-variable name="foundry-project-id" value="@(context.Request.Headers.GetValueOrDefault(&quot;x-ms-foundry-project-id&quot;, &quot;&quot;))" />

        <!-- CORS for Azure AI Foundry portal -->
        <cors allow-credentials="true">
            <allowed-origins>
                <origin>https://ai.azure.com</origin>
            </allowed-origins>
            <allowed-methods preflight-result-max-age="300">
                <method>*</method>
            </allowed-methods>
            <allowed-headers>
                <header>*</header>
            </allowed-headers>
            <expose-headers>
                <header>*</header>
            </expose-headers>
        </cors>

        <!-- Authenticate to backend with APIM's managed identity -->
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="managed-id-access-token" ignore-error="false" />
        <set-header name="Authorization" exists-action="override">
            <value>@("Bearer " + (string)context.Variables["managed-id-access-token"])</value>
        </set-header>

        <!-- Emit token metrics with caller + routing dimensions (generic LLM) -->
        <llm-emit-token-metric namespace="llm">
            <dimension name="Caller ID" value="@((string)context.Variables[&quot;caller-id&quot;])" />
            <dimension name="Caller Name" value="@((string)context.Variables[&quot;caller-name&quot;])" />
            <dimension name="Priority" value="@((string)context.Variables[&quot;priority-label&quot;])" />
            <dimension name="Route Target" value="@((string)context.Variables[&quot;route-target&quot;])" />
            <dimension name="Model" value="@((string)context.Variables[&quot;requestedModel&quot;])" />
            <dimension name="API ID" value="@(context.Api.Id)" />
        </llm-emit-token-metric>
    </inbound>

    <backend>
        <!-- Forward to the backend pool chosen in inbound.                         -->
        <!-- Mixed pool: circuit breaker handles PTU→PAYG failover automatically.   -->
        <!-- PAYG pool: direct to PAYG backends.                                    -->
        <forward-request buffer-request-body="true" />
    </backend>

    <outbound>
        <base />

        <!-- ================================================================ -->
        <!-- Detect backend type (PTU vs PAYG) after pool failover             -->
        <!--                                                                  -->
        <!-- context.Backend.* returns pool-level values after failover, but  -->
        <!-- context.Request.Url.Host reflects the RESOLVED backend host.     -->
        <!-- We compare it against the known PTU hosts list injected by IaC.  -->
        <!-- ================================================================ -->
        <set-variable name="backend-type" value="@{
            var host = context.Request.Url.Host.ToLowerInvariant();
            var ptuHosts = &quot;{ptu-backend-hosts}&quot;.ToLowerInvariant();
            if (!string.IsNullOrEmpty(ptuHosts)) {
                foreach (var ptuHost in ptuHosts.Split(',')) {
                    if (host == ptuHost.Trim()) {
                        return &quot;ptu&quot;;
                    }
                }
            }
            // Fallback: if route-target was set to payg, trust it
            var target = (string)context.Variables.GetValueOrDefault(&quot;route-target&quot;, &quot;&quot;);
            if (target == &quot;payg&quot;) {
                return &quot;payg&quot;;
            }
            return &quot;unknown&quot;;
        }" />

        <!-- ================================================================ -->
        <!-- Response headers for observability                               -->
        <!-- ================================================================ -->
        <set-header name="x-ratelimit-limit-tokens" exists-action="override">
            <value>@(((int)context.Variables["model-tpm"]).ToString())</value>
        </set-header>
        <set-header name="x-quota-limit-tokens" exists-action="override">
            <value>@(((long)context.Variables["caller-monthly-quota"]).ToString())</value>
        </set-header>
        <!-- Production callers with 100% PTU skip monthly quota (Step 7b), so the header is never set.
             Default to the full quota so observability headers are always present. -->
        <choose>
            <when condition="@(!context.Response.Headers.ContainsKey(&quot;x-quota-remaining-tokens&quot;))">
                <set-header name="x-quota-remaining-tokens" exists-action="override">
                    <value>@(((long)context.Variables["caller-monthly-quota"]).ToString())</value>
                </set-header>
            </when>
        </choose>
        <set-header name="x-caller-name" exists-action="override">
            <value>@((string)context.Variables["caller-name"])</value>
        </set-header>
        <set-header name="x-caller-identity" exists-action="override">
            <value>@((string)context.Variables.GetValueOrDefault("matched-identity", "unknown"))</value>
        </set-header>
        <set-header name="x-caller-priority" exists-action="override">
            <value>@((string)context.Variables["priority-label"])</value>
        </set-header>
        <set-header name="x-route-target" exists-action="override">
            <value>@((string)context.Variables["route-target"])</value>
        </set-header>
        <set-header name="x-ptu-limit" exists-action="override">
            <value>@(((int)context.Variables["model-ptu-tpm"]).ToString())</value>
        </set-header>
        <set-header name="x-backend-type" exists-action="override">
            <value>@((string)context.Variables["backend-type"])</value>
        </set-header>
        <set-header name="x-backend-id" exists-action="override">
            <value>@(context.Backend?.Id ?? "unknown")</value>
        </set-header>
        <set-header name="x-backend-pool" exists-action="override">
            <value>@((string)context.Variables["backend-pool"])</value>
        </set-header>

        <!-- Foundry-specific headers (logged via API diagnostics → App Insights) -->
        <set-header name="x-foundry-agent-id" exists-action="override">
            <value>@((string)context.Variables["foundry-agent-id"])</value>
        </set-header>
        <set-header name="x-foundry-project-name" exists-action="override">
            <value>@((string)context.Variables["foundry-project-name"])</value>
        </set-header>
        <set-header name="x-foundry-project-id" exists-action="override">
            <value>@((string)context.Variables["foundry-project-id"])</value>
        </set-header>
    </outbound>

    <on-error>
        <base />
        <!-- ================================================================ -->
        <!-- EVENT HUB: Emit quota-exceeded event when monthly quota is hit   -->
        <!-- ================================================================ -->
        <!-- Event Hub logging disabled — enable by adding eventhub module -->
        <return-response>
            <set-status code="@{
                var source = context.LastError?.Source ?? "";
                var reason = context.LastError?.Reason ?? "";
                if (source == "validate-azure-ad-token" || source == "validate-jwt") { return 401; }
                if (source == "llm-token-limit") {
                    return reason.Contains("Quota") ? 403 : 429;
                }
                if (context.Response != null) { return context.Response.StatusCode; }
                return 500;
            }" reason="@(context.LastError?.Reason ?? (context.Response != null ? context.Response.StatusReason : "Internal Server Error"))" />
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-header name="x-error-reason" exists-action="override">
                <value>@(context.LastError?.Reason ?? "unknown")</value>
            </set-header>
            <set-header name="x-error-message" exists-action="override">
                <value>@(context.LastError?.Message ?? "unknown")</value>
            </set-header>
            <set-header name="x-error-section" exists-action="override">
                <value>@(context.LastError?.Section ?? "unknown")</value>
            </set-header>
            <set-header name="x-error-source" exists-action="override">
                <value>@(context.LastError?.Source ?? "unknown")</value>
            </set-header>
            <set-header name="x-caller-id" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("caller-id", "unknown"))</value>
            </set-header>
            <set-header name="x-caller-name" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("caller-name", "unknown"))</value>
            </set-header>
            <set-header name="x-caller-identity" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("matched-identity", "unknown"))</value>
            </set-header>
            <set-header name="x-caller-priority" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("priority-label", "unknown"))</value>
            </set-header>
            <set-header name="x-route-target" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("route-target", "unknown"))</value>
            </set-header>
            <set-header name="x-ratelimit-limit-tokens" exists-action="override">
                <value>@(context.Variables.ContainsKey("model-tpm") ? ((int)context.Variables["model-tpm"]).ToString() : "0")</value>
            </set-header>
            <set-header name="x-quota-limit-tokens" exists-action="override">
                <value>@(context.Variables.ContainsKey("caller-monthly-quota") ? ((long)context.Variables["caller-monthly-quota"]).ToString() : "0")</value>
            </set-header>
            <set-header name="x-ptu-limit" exists-action="override">
                <value>@(context.Variables.ContainsKey("model-ptu-tpm") ? ((int)context.Variables["model-ptu-tpm"]).ToString() : "0")</value>
            </set-header>
            <set-header name="x-ratelimit-remaining-tokens" exists-action="override">
                <value>0</value>
            </set-header>
            <set-header name="x-quota-remaining-tokens" exists-action="override">
                <value>0</value>
            </set-header>
            <set-header name="x-backend-pool" exists-action="override">
                <value>@((string)context.Variables.GetValueOrDefault("backend-pool", "unknown"))</value>
            </set-header>
            <set-body>@{
                var source  = context.LastError?.Source ?? "";
                var reason  = context.LastError?.Reason ?? "unknown";
                var rawMsg  = context.LastError?.Message ?? "";
                var team    = (string)context.Variables.GetValueOrDefault("caller-name", "unknown");
                var model   = (string)context.Variables.GetValueOrDefault("requestedModel", "unknown");

                string code;
                string message;

                if (source == "validate-azure-ad-token")
                {
                    code = "unauthorized";
                    message = "Invalid or missing bearer token. Provide a valid Entra ID token with audience https://cognitiveservices.azure.com.";
                }
                else if (rawMsg.Contains("quota"))
                {
                    var quota = context.Variables.ContainsKey("caller-monthly-quota")
                        ? ((long)context.Variables["caller-monthly-quota"]).ToString("N0")
                        : "unknown";
                    code = "monthly_quota_exceeded";
                    message = "Monthly token quota exhausted for '" + team + "'. "
                            + "Your contract allows " + quota + " tokens per month across all models. "
                            + "Contact the platform team to request a quota increase.";
                }
                else if (source == "llm-token-limit")
                {
                    var tpm = context.Variables.ContainsKey("model-tpm")
                        ? ((int)context.Variables["model-tpm"]).ToString("N0")
                        : "unknown";
                    code = "rate_limit_exceeded";
                    message = "Per-model rate limit exceeded for '" + team + "' on model '" + model + "'. "
                            + "Your contract allows " + tpm + " tokens per minute for this model. "
                            + "Wait a moment and retry, or contact the platform team to request a higher limit.";
                }
                else
                {
                    code = reason;
                    message = !string.IsNullOrEmpty(rawMsg) ? rawMsg : "An error occurred processing the request.";
                }

                return new Newtonsoft.Json.Linq.JObject(
                    new Newtonsoft.Json.Linq.JProperty("error", new Newtonsoft.Json.Linq.JObject(
                        new Newtonsoft.Json.Linq.JProperty("code", code),
                        new Newtonsoft.Json.Linq.JProperty("message", message)
                    ))
                ).ToString();
            }</set-body>
        </return-response>
    </on-error>
</policies>
