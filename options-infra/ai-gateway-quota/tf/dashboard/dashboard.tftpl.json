                "name": "PartSubTitle",
                "value": "Hourly token consumption by project/subscription",
                "isOptional": true
              },
              {
                "name": "Query",
                "value": "let llmLogs = ApiManagementGatewayLlmLog\n| where isnotempty(DeploymentName)\n| project TimeGenerated, TotalTokens, CorrelationId;\nlet callers = ApiManagementGatewayLogs\n| where BackendRequestHeaders has \"x-caller-name\"\n| extend CallerName = extract(@'\"x-caller-name\":\"([^\"]+)\"', 1, tostring(BackendRequestHeaders))\n| summarize CallerName = any(CallerName) by CorrelationId;\nllmLogs\n| join kind=leftouter callers on CorrelationId\n| extend CallerName = coalesce(CallerName, \"Unknown\")\n| summarize TotalTokens = sum(TotalTokens) by bin(TimeGenerated, 1h), CallerName\n| order by TimeGenerated asc",
                "isOptional": true
              },
              {
                "name": "ControlType",
                "value": "AnalyticsGrid",
                "isOptional": true
              },
              {
                "name": "resourceTypeMode",
                "isOptional": true
