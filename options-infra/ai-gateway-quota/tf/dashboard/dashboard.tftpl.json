              {
                "name": "ComponentId",
                "isOptional": true
              },
              {
                "name": "DashboardId",
                "isOptional": true
              },
              {
                "name": "DraftRequestParameters",
                "isOptional": true
              },
              {
                "name": "SpecificChart",
                "isOptional": true
              },
              {
                "name": "Dimensions",
                "isOptional": true
              },
              {
                "name": "LegendOptions",
                "isOptional": true
              },
              {
                "name": "IsQueryContainTimeRange",
                "isOptional": true
              }
            ],
            "settings": {
              "content": {
                "ControlType": "FrameControlChart",
                "SpecificChart": "StackedColumn",
                "Dimensions": {
                  "xAxis": {
                    "name": "TimeGenerated",
                    "type": "datetime"
                  },
                  "yAxis": [
                    {
                      "name": "TotalTokens",
                      "type": "long"
                    }
                  ],
                  "splitBy": [
                    {
                      "name": "CallerName",
                      "type": "string"
                    }
                  ],
                  "aggregation": "Sum"
                },
                "LegendOptions": {
                  "isEnabled": true,
                  "position": "Bottom"
                }
              }
            }
