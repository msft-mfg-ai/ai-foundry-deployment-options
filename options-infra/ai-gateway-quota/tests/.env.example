# Required
APIM_GATEWAY_URL=https://<your-apim-name>.azure-api.net
TENANT_ID=<tenant-id>

# Authentication: choose one
# Option A: app registration / service principal
CLIENT_ID=<app-client-id>
CLIENT_SECRET=<app-client-secret>

# Option B: leave CLIENT_ID/CLIENT_SECRET empty and use `az login`
# Option C: paste a pre-minted token for https://cognitiveservices.azure.com
# TEST_ACCESS_TOKEN=<bearer-token>

# Optional, only if your APIM deployment requires a subscription key
# APIM_SUBSCRIPTION_KEY=<apim-subscription-key>

# Optional: APIM SKU. Used to skip tests that require features only available
# on higher tiers. The OpenAI v1 spec (`/openai-v1/*`) needs 100+ API
# operations, which only StandardV2 and Premium support — set to a lower
# value (BasicV2 / Developer / Consumption) and test_openai_v1_surface
# will be skipped instead of failing.
# APIM_SKU=StandardV2

# Optional test overrides
TEST_MODEL=gpt-4.1-mini
TEST_FAILOVER_MODEL=gpt-4.1-mini
TEST_CONTRACT=Team Alpha
API_VERSION=2025-03-01-preview
AUDIENCE=https://cognitiveservices.azure.com
